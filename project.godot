; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Bazookat"
run/main_scene="uid://c0sx1pdbfi5kb"
config/use_custom_user_dir=true
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*uid://htvfombsjd2q"
UIManager="*uid://ce5vl4amnusnw"
LevelManager="*uid://yerdyldt41j7"
PersistDataManager="*uid://biy5b5a34qbfe"

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/mode=3
window/stretch/mode="viewport"
window/stretch/aspect="keep_width"
mouse_cursor/custom_image="uid://d1yrvmlx3w4d1"
mouse_cursor/custom_image_hotspot=Vector2(32, 32)

[editor_plugins]

enabled=PackedStringArray("res://addons/AS2P/plugin.cfg")

[global_group]

Player=""
MainScene="Used to detect weather or not we're running the main scene or not"

